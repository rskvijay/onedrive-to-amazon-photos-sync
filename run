#!/usr/bin/env bash
set -e
cd "$(dirname "$0")"

ROOT="$(pwd)"
VENV="${ROOT}/.venv"
PYTHON="${VENV}/bin/python"
REQUIREMENTS="${ROOT}/requirements.txt"

if [[ ! -d "$VENV" ]]; then
  echo "Creating virtual environment at ${VENV}..."
  python3 -m venv "$VENV"
fi

if [[ ! -x "$PYTHON" ]]; then
  echo "Creating virtual environment at ${VENV}..."
  python3 -m venv "$VENV"
fi

# Ensure dependencies are installed (idempotent)
"$PYTHON" -m pip install -q -r "$REQUIREMENTS"

exec "$PYTHON" main.py "$@"
