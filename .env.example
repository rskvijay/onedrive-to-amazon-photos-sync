# Copy to .env and fill in your values. Do not commit .env.

# --- OneDrive (for --list-onedrive-photos) ---
# Azure AD app (Microsoft Entra) client ID. Register at https://portal.azure.com/
# with delegated permissions User.Read, Files.Read and Device code flow.
ONEDRIVE_CLIENT_ID="your-azure-app-client-id"

# --- Amazon Photos (for --list-amazon-photos) ---
# Get from browser cookies at https://www.amazon.com/photos/ (DevTools → Application → Cookies)
# US:
AMAZON_SESSION_ID="..."
AMAZON_UBID_MAIN="..."
AMAZON_AT_MAIN="..."
# Canada/other: use AMAZON_UBID_ACBCA and AMAZON_AT_ACBCA instead of UBID_MAIN / AT_MAIN
